# Frontend environment variables (Vite)
# For local dev:
VITE_API_BASE_URL=http://localhost:4000

# For Render deployment, set VITE_API_BASE_URL in Render's Environment dashboard:
# VITE_API_BASE_URL=https://your-backend.onrender.com

# Optional: pre-bake an API key at build time (or leave blank and set in-browser)
VITE_API_KEY=
