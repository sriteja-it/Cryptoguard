# REQUIRED: MongoDB connection string (local or Atlas)
MONGODB_URI=mongodb://localhost:27017

# Optional: MongoDB database name (defaults to darkmode_pqc)
MONGODB_DB_NAME=darkmode_pqc

# Optional: Admin token for protected /admin/* endpoints (change in production!)
ADMIN_TOKEN=dev_admin_token

# Optional: Port to start on (auto-increments if in use)
PORT=4000

# Optional: Path to Python executable (auto-detected if omitted)
# PYTHON_BIN=/usr/bin/python3
